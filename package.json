{
  "name": "footnote-writer",
  "version": "1.0.2",
  "description": "学术写作脚注助手 — AI辅助生成原生Word脚注",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron dist/main/main/index.js",
    "pack": "npm run build && electron-builder"
  },
  "dependencies": {
    "@tiptap/core": "^2.11.0",
    "@tiptap/extension-document": "^2.11.0",
    "@tiptap/extension-heading": "^2.11.0",
    "@tiptap/extension-paragraph": "^2.11.0",
    "@tiptap/extension-text": "^2.11.0",
    "@tiptap/extension-bold": "^2.11.0",
    "@tiptap/extension-italic": "^2.11.0",
    "@tiptap/extension-history": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/pm": "^2.11.0",
    "@tiptap/react": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "better-sqlite3": "^11.7.0",
    "docx": "^9.1.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react-markdown": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/pdf-parse": "^1.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
